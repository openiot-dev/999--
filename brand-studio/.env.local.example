# Anthropic API 키 (필수) — https://console.anthropic.com 에서 발급
# 실제 키는 .env.local 에 넣으세요(이 .example 파일은 커밋되므로 비밀키 금지).
ANTHROPIC_API_KEY=sk-ant-...

# (선택) 모델 / 사고 강도 / 출력 한도
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_EFFORT=medium      # low | medium | high | max
# ANTHROPIC_MAX_TOKENS=32000   # 다편 결과(릴스 3편 등) 잘림 방지

# 사내 로그인 게이트 (APP_PASSWORD 설정 시 활성화 — 미설정 시 게이트 꺼짐)
# APP_PASSWORD=사내공유비밀번호
# APP_SESSION_SECRET=랜덤긴문자열   # 권장: openssl rand -hex 32 (미설정 시 APP_PASSWORD 로 파생)

# (선택) 공개 배포 시 남용 방지 — 동일 출처 외 호출 차단 / IP당 분당 요청 수
# APP_ALLOWED_ORIGINS=https://your-domain.com
# APP_RATE_LIMIT=20

# (선택) 회사 지식베이스 자동 동기화(pnpm sync)용
# GITHUB_TOKEN=ghp_...   # 없으면 로컬 gh CLI 사용
# NOTION_TOKEN=ntn_...   # 노션 내부 통합 토큰(페이지를 통합에 연결해야 동작). 미설정 시 노션 생략
